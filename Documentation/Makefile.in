Makefile: $(srcdir)/Makefile.in  $(top_builddir)/config.status
	cd $(top_builddir) \
	  && CONFIG_FILES=$(subdir)/$@ CONFIG_HEADERS= $(SHELL) ./config.status


install-docsDATA: $(docs_DATA)
	@$(NORMAL_INSTALL)
	$(mkinstalldirs) $(DESTDIR)$(docsdir)
	@list='$(docs_DATA)'; for p in $$list; do \
	  if test -f $(srcdir)/$$p; then \
	    echo " $(INSTALL_DATA) $(srcdir)/$$p $(DESTDIR)$(docsdir)/$$p"; \
	    $(INSTALL_DATA) $(srcdir)/$$p $(DESTDIR)$(docsdir)/$$p; \
	  else if test -f $$p; then \
	    echo " $(INSTALL_DATA) $$p $(DESTDIR)$(docsdir)/$$p"; \
	    $(INSTALL_DATA) $$p $(DESTDIR)$(docsdir)/$$p; \
	  fi; fi; \
	done

uninstall-docsDATA:
	@$(NORMAL_UNINSTALL)
	list='$(docs_DATA)'; for p in $$list; do \
	  rm -f $(DESTDIR)$(docsdir)/$$p; \
	done

install-rtbinfoDATA: $(rtbinfo_DATA)
	@$(NORMAL_INSTALL)
	$(mkinstalldirs) $(DESTDIR)$(rtbinfodir)
	@list='$(rtbinfo_DATA)'; for p in $$list; do \
	  if test -f $(srcdir)/$$p; then \
	    echo " $(INSTALL_DATA) $(srcdir)/$$p $(DESTDIR)$(rtbinfodir)/$$p"; \
	    $(INSTALL_DATA) $(srcdir)/$$p $(DESTDIR)$(rtbinfodir)/$$p; \
	  else if test -f $$p; then \
	    echo " $(INSTALL_DATA) $$p $(DESTDIR)$(rtbinfodir)/$$p"; \
	    $(INSTALL_DATA) $$p $(DESTDIR)$(rtbinfodir)/$$p; \
	  fi; fi; \
	done

uninstall-rtbinfoDATA:
	@$(NORMAL_UNINSTALL)
	list='$(rtbinfo_DATA)'; for p in $$list; do \
	  rm -f $(DESTDIR)$(rtbinfodir)/$$p; \
	done
tags: TAGS
TAGS:


distdir = $(top_builddir)/$(PACKAGE)-$(VERSION)/$(subdir)

subdir = Documentation

distdir: $(DISTFILES)
	@for file in $(DISTFILES); do \
	  d=$(srcdir); \
	  if test -d $$d/$$file; then \
	    cp -pr $$d/$$file $(distdir)/$$file; \
	  else \
	    test -f $(distdir)/$$file \
	    || ln $$d/$$file $(distdir)/$$file 2> /dev/null \
	    || cp -p $$d/$$file $(distdir)/$$file || :; \
	  fi; \
	done
