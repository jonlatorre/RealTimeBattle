	  && CONFIG_FILES=$(subdir)/$@ CONFIG_HEADERS= $(SHELL) ./config.status


mostlyclean-robotexecPROGRAMS:

clean-robotexecPROGRAMS:
	-test -z "$(robotexec_PROGRAMS)" || rm -f $(robotexec_PROGRAMS)

distclean-robotexecPROGRAMS:

maintainer-clean-robotexecPROGRAMS:

install-robotexecPROGRAMS: $(robotexec_PROGRAMS)
	@$(NORMAL_INSTALL)
	$(mkinstalldirs) $(DESTDIR)$(robotexecdir)
	@list='$(robotexec_PROGRAMS)'; for p in $$list; do \
	  if test -f $$p; then \
	    echo "  $(INSTALL_PROGRAM) $$p $(DESTDIR)$(robotexecdir)/`echo $$p|sed 's/$(EXEEXT)$$//'|sed '$(transform)'|sed 's/$$/$(EXEEXT)/'`"; \
	     $(INSTALL_PROGRAM) $$p $(DESTDIR)$(robotexecdir)/`echo $$p|sed 's/$(EXEEXT)$$//'|sed '$(transform)'|sed 's/$$/$(EXEEXT)/'`; \
	  else :; fi; \
	done

uninstall-robotexecPROGRAMS:
	@$(NORMAL_UNINSTALL)
	list='$(robotexec_PROGRAMS)'; for p in $$list; do \
	  rm -f $(DESTDIR)$(robotexecdir)/`echo $$p|sed 's/$(EXEEXT)$$//'|sed '$(transform)'|sed 's/$$/$(EXEEXT)/'`; \
	done

.c.o:
	$(COMPILE) -c $<

.s.o:
	$(COMPILE) -c $<

.S.o:
	$(COMPILE) -c $<

